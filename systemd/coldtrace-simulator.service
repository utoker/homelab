[Unit]
Description=ColdTrace vaccine device simulator (writes readings via GraphQL)
After=coldtrace-backend.service
Wants=coldtrace-backend.service

[Service]
Type=simple
User=umut
Group=umut
WorkingDirectory=/home/umut/coldtrace/apps/simulator
EnvironmentFile=/home/umut/coldtrace/apps/simulator/.env
ExecStart=/usr/bin/node dist/index.js
Restart=always
RestartSec=10
MemoryMax=200M

[Install]
WantedBy=multi-user.target
